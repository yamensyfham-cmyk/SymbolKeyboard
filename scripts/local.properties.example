# SymbolKeyboard signing configuration
# Copy this file to local.properties and fill in your values.
# For development, run scripts/gen-debug-keystore.sh first.

# Debug keystore (development)
keystore.path=${HOME}/.android/debug.keystore
keystore.password=android
key.alias=androiddebugkey
key.password=android

# Release keystore (for signed builds)
# keystore.path=/path/to/your/release.keystore
# keystore.password=your_store_password
# key.alias=your_key_alias
# key.password=your_key_password
